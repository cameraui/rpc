{
  "name": "@camera.ui/rpc-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "camera.ui rpc monorepo",
  "type": "module",
  "scripts": {
    "build:node": "npm --prefix node run build",
    "build:go": "cd go && go build ./...",
    "build:python": "cd python && python scripts/build.py --local",
    "build": "npm run build:node && npm run build:go && npm run build:python",
    "lint:node": "npm --prefix node run format && npm --prefix node run lint:fix",
    "lint:go": "cd go && gofmt -w . && go fix ./... && staticcheck ./... && golangci-lint run ./...",
    "lint:python": "cd python && mypy --config-file ../mypy.ini camera_ui_rpc",
    "lint": "npm run lint:node && npm run lint:go && npm run lint:python",
    "test:unit:node": "npm --prefix node test",
    "test:unit:go": "cd go && go test ./...",
    "test:unit:python": "cd python && python -m pytest",
    "test:unit": "npm run test:unit:node && npm run test:unit:go && npm run test:unit:python",
    "test:codec": "bash tests/run-codec-tests.sh",
    "test:pull-callback": "bash tests/run-pull-callback-cross.sh",
    "test:rpc": "bash tests/run-cross-rpc-test.sh",
    "test:integration": "npm run test:codec && npm run test:pull-callback && npm run test:rpc",
    "test": "npm run test:unit && npm run test:integration",
    "update": "updates --file go,node,python --update ./"
  },
  "homepage": "https://github.com/cameraui/rpc#readme",
  "bugs": {
    "url": "https://github.com/cameraui/rpc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameraui/rpc.git"
  },
  "license": "MIT",
  "author": "seydx",
  "devDependencies": {
    "@camera.ui/nats": "^0.0.28",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/node": "^25.9.3",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "10.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.61.0",
    "updates": "^17.18.0"
  }
}
